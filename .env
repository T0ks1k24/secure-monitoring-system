# ================================================================
# Конфігурація Secure Monitoring System
# ================================================================
# Для cloud:  docker compose -f docker-compose.cloud.yml up -d
# Для local:  docker compose -f docker-compose.local.yml up -d
# ================================================================

# ── Хмарний сервер ───────────────────────────────────────────────
# Публічний IP або домен (без http://)
# Використовується в docker-compose.cloud.yml (EVIDENCE_PUBLIC_BASE_URL)
CLOUD_HOST=localhost

# ── PostgreSQL (cloud) ───────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=security_db

# ── RabbitMQ (cloud) ─────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ── Безпека бекенду (cloud) ──────────────────────────────────────
# Генерація: openssl rand -hex 32
SECRET_KEY=super-secret-change-me-in-production

# CORS: перелік через кому або * для всіх
ALLOWED_ORIGINS=*

# ── Версія Docker-образів ────────────────────────────────────────
APP_VERSION=latest

# ================================================================
# Локальний стек (docker-compose.local.yml)
# ВАЖЛИВО: замінити localhost на реальний IP хмарного сервера!
# Приклад: AI_SERVICE_URL=http://203.0.113.10:5000/api/v1/detect
# ================================================================

# URL хмарного AI-сервісу (для frame_extractor)
# Якщо cloud і local на одній машині — використовуємо ім'я контейнера (через security_net)
AI_SERVICE_URL=http://ai_model_service:5000/api/v1/detect

# URL хмарного бекенду (для frontend)
VITE_API_URL=http://localhost:8000

# URL локального frame_extractor (для frontend)
VITE_FRAME_API_URL=http://localhost:8100

# URL локального MediaMTX (HLS / WebRTC відео)
VITE_MEDIA_MTX_HLS_URL=http://localhost:8888
VITE_MEDIA_MTX_WEBRTC_URL=http://localhost:8889

# WebSocket подій — хмарний бекенд
VITE_WS_EVENTS_URL=ws://localhost:8000/ws/events
