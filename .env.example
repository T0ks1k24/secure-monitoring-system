# ============================================================
# Cloud Stack (.env для docker-compose.cloud.yml)
# Запуск: docker compose -f docker-compose.cloud.yml up -d
# ============================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=security_db

RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ============================================================
# Local Stack (.env для docker-compose.local.yml)
# Запуск: docker compose -f docker-compose.local.yml up -d
# ============================================================

# IP або домен cloud-сервера де запущено ai_service (порт 5000)
AI_SERVICE_URL=http://<CLOUD_SERVER_IP>:5000/api/v1/detect

# IP або домен cloud-сервера де запущено backend (порт 8000)
VITE_API_URL=http://<CLOUD_SERVER_IP>:8000
